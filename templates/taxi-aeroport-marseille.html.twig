{% extends 'base.html.twig' %}

{% block title %}Taxi Aéroport Marseille-Provence Marignane — Appel 06 74 03 96 94 | ZenCAR{% endblock %}

{% block meta %}
<meta name="description" content="Taxi pour l'aéroport Marseille-Provence Marignane. Suivi de vol, chauffeur à l'arrivée bagages. Appelez le 06 74 03 96 94 — disponible 24h/24, 7j/7." />
<meta name="robots" content="index, follow" />
{% endblock %}

{% block og %}
<meta property="og:title" content="Taxi & VTC Aéroport Marseille-Provence — ZenCAR" />
<meta property="og:description" content="Taxi au compteur ou VTC prix fixe pour l'aéroport de Marseille. Suivi de vol, prise en charge garantie. 06 74 03 96 94." />
<meta property="og:url" content="https://dzencar.fr/taxi-aeroport-marseille" />
<meta property="og:type" content="website" />
{% endblock %}

{% block canonical %}
<link rel="canonical" href="https://dzencar.fr/taxi-aeroport-marseille" />
{% endblock %}

{% block jsonld %}
<script type="application/ld+json">
[
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://dzencar.fr/" },
      { "@type": "ListItem", "position": 2, "name": "Taxi Marseille", "item": "https://dzencar.fr/taxi-marseille" },
      { "@type": "ListItem", "position": 3, "name": "Aéroport Marseille" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "TaxiService",
    "name": "ZenCAR — Taxi & VTC Aéroport Marseille-Provence",
    "url": "https://dzencar.fr/taxi-aeroport-marseille",
    "telephone": "+33674039694",
    "description": "Service Taxi et VTC pour l'aéroport Marseille-Provence. Taxi au compteur tarifs officiels Ville de Marseille, VTC prix fixe affiché avant réservation.",
    "areaServed": [
      { "@type": "Airport", "name": "Aéroport Marseille-Provence", "iataCode": "MRS" },
      { "@type": "City", "name": "Marseille" }
    ],
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
      "opens": "00:00",
      "closes": "23:59"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Quel est le tarif taxi de Marseille à l'aéroport ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Le tarif taxi est fixé par le compteur selon les tarifs officiels réglementés par la Ville de Marseille. Pour un VTC, le prix fixe est calculé et affiché avant votre confirmation de réservation."
        }
      },
      {
        "@type": "Question",
        "name": "Combien de temps dure le trajet entre Marseille et l'aéroport ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Le trajet entre le centre de Marseille et l'aéroport Marseille-Provence (Marignane) dure environ 25 à 45 minutes selon le trafic. Comptez 30 km environ."
        }
      },
      {
        "@type": "Question",
        "name": "ZenCAR suit-il les vols en temps réel ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Oui, nous suivons votre vol en temps réel. En cas de retard, votre chauffeur adapte l'heure de prise en charge automatiquement."
        }
      },
      {
        "@type": "Question",
        "name": "Peut-on réserver un taxi pour l'aéroport à l'avance ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Oui, vous pouvez réserver à l'avance via notre formulaire de réservation en ligne ou par téléphone au 06 74 03 96 94."
        }
      }
    ]
  }
]
</script>
{% endblock %}

