{% extends 'base.html.twig' %}

{% block title %}Transport Seniors Marseille — Taxi & Accompagnement | ZenCAR{% endblock %}

{% block meta %}
<meta name="description" content="Service de transport dédié aux personnes âgées à Marseille. Courses, médecin, promenades, EHPAD. Chauffeurs bienveillants, aide montée/descente. Appelez le 06 74 03 96 94." />
<meta name="robots" content="index, follow" />
{% endblock %}

{% block canonical %}
<link rel="canonical" href="https://dzencar.fr/transport-seniors-marseille" />
{% endblock %}

{% block og_title %}Transport Seniors Marseille — ZenCAR{% endblock %}
{% block og_description %}Taxi et accompagnement pour personnes âgées à Marseille. Courses, médicaux, promenades, EHPAD. Chauffeurs patients. 06 74 03 96 94{% endblock %}
{% block og_url %}https://dzencar.fr/transport-seniors-marseille{% endblock %}

{% block jsonld %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "TaxiService",
  "name": "ZenCAR — Transport Seniors Marseille",
  "url": "https://dzencar.fr/transport-seniors-marseille",
  "telephone": "+33674039694",
  "description": "Service de transport et d'accompagnement pour personnes âgées à Marseille. Courses, rendez-vous médicaux, promenades, conventions EHPAD.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Marseille",
    "addressRegion": "Provence-Alpes-Côte d'Azur",
    "addressCountry": "FR"
  },
  "areaServed": {"@type": "City", "name": "Marseille"}
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://dzencar.fr/"},
    {"@type": "ListItem", "position": 2, "name": "Taxi Marseille", "item": "https://dzencar.fr/taxi-marseille"},
    {"@type": "ListItem", "position": 3, "name": "Transport Seniors", "item": "https://dzencar.fr/transport-seniors-marseille"}
  ]
}
</script>
{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<style>
  :root {
    --zen-green:      #1D9E75;
    --zen-green-dark: #0F6E56;
    --zen-bg-light:   #E1F5EE;
    --zen-dark:       #1A1A18;
    --zen-orange:     #e65100;
    --zen-orange-bg:  #fff8f0;
  }
  .seniors-hero {
    background: linear-gradient(135deg, #e65100 0%, #ff8f00 100%);
    color: white;
    padding: 80px 0 60px;
    text-align: center;
  }
  .seniors-hero h1 { font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 800; }
  .zen-section { padding: 60px 0; }
  .zen-section-alt { background: var(--zen-bg-light); }
  .zen-section-title { color: var(--zen-green-dark); font-weight: 700; font-size: 1.6rem; margin-bottom: 8px; }
  .service-card {
    background: white;
    border-radius: 14px;
    padding: 28px 22px;
    height: 100%;
    border: 1px solid #ffe0cc;
    transition: box-shadow .2s, transform .2s;
  }
  .service-card:hover { box-shadow: 0 8px 24px rgba(230,81,0,.12); transform: translateY(-4px); }
  .service-card .icon { font-size: 2rem; color: var(--zen-orange); margin-bottom: 14px; }
  .service-card h3 { font-size: 1rem; font-weight: 700; }
  .service-card p  { font-size: .88rem; color: #666; }
  .guarantee-badge {
    display: flex; align-items: center; gap: 12px;
    background: white; border-radius: 12px; padding: 16px 20px;
    border-left: 4px solid var(--zen-orange); margin-bottom: 14px;
    box-shadow: 0 2px 8px rgba(0,0,0,.06);
  }
  .guarantee-badge .icon { font-size: 1.4rem; color: var(--zen-orange); min-width: 30px; }
  #floating-contact {
    position: fixed; bottom: 24px; right: 20px;
    display: flex; flex-direction: column; gap: 12px; z-index: 999;
  }
  .btn-call     { background: #1976d2; color: white; font-size: 1.3rem; width: 54px; height: 54px; display: flex; align-items: center; justify-content: center; }
  .btn-whatsapp { background: #25d366; color: white; font-size: 1.3rem; width: 54px; height: 54px; display: flex; align-items: center; justify-content: center; }
</style>
{% endblock %}

{% block body %}

<div id="floating-contact">
  <a href="tel:+33674039694" class="btn btn-call rounded-circle shadow-sm" title="Appeler ZenCAR">
    <i class="bi bi-telephone-fill"></i>
  </a>
  <a href="https://wa.me/33674039694" target="_blank" class="btn btn-whatsapp rounded-circle shadow-sm" title="WhatsApp ZenCAR">
    <i class="bi bi-whatsapp"></i>
  </a>
</div>

{# ── Fil d'Ariane ─────────────────────────────────────────────────── #}
<div style="background:#f8f9fa; border-bottom:1px solid #e9ecef;">
  <div class="container py-2">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-0" style="font-size:.85rem;">
        <li class="breadcrumb-item"><a href="{{ path('app_home') }}" style="color:var(--zen-green);">Accueil</a></li>
        <li class="breadcrumb-item"><a href="{{ path('app_taxi_marseille') }}" style="color:var(--zen-green);">Taxi Marseille</a></li>
        <li class="breadcrumb-item active">Transport Seniors</li>
      </ol>
    </nav>
  </div>
</div>

{# ── Hero ──────────────────────────────────────────────────────────── #}
<section class="seniors-hero">
  <div class="container">
    <span style="display:inline-block;background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.4);border-radius:50px;padding:6px 18px;font-size:.9rem;margin-bottom:16px;">
      ❤️ Service senior bienveillant
    </span>
    <h1>Transport Seniors & EHPAD à Marseille</h1>
    <p class="lead mt-3 mb-4" style="opacity:.9; max-width:620px; margin:auto;">
      Chauffeurs patients et attentionnés, aide à la montée et descente.
      <strong>Disponible 7j/7</strong> pour tous vos déplacements.
    </p>
    <div class="d-flex flex-wrap justify-content-center gap-3">
      <a href="tel:+33674039694" class="btn btn-light btn-lg fw-bold px-4" style="color:var(--zen-orange);border-radius:50px;">
        <i class="bi bi-telephone-fill me-2"></i>06 74 03 96 94
      </a>
      <a href="https://wa.me/33674039694" class="btn btn-success btn-lg fw-bold px-4" style="border-radius:50px;">
        <i class="bi bi-whatsapp me-2"></i>WhatsApp
      </a>
    </div>
  </div>
</section>

{# ── Services seniors ──────────────────────────────────────────────── #}
<section class="zen-section">
  <div class="container">
    <h2 class="zen-section-title text-center">Nos services pour personnes âgées à Marseille</h2>
    <p class="text-center text-muted mb-5">Un chauffeur dévoué pour tous vos besoins du quotidien.</p>

    <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-lg-3">

      <div class="col">
        <div class="service-card">
          <div class="icon"><i class="fas fa-shopping-basket"></i></div>
          <h3>Courses & Supermarchés</h3>
          <p>Accompagnement aux courses alimentaires, pharmacie, marchés de Noailles, La Plaine. Le chauffeur vous aide avec vos sacs.</p>
        </div>
      </div>

      <div class="col">
        <div class="service-card">
          <div class="icon"><i class="fas fa-stethoscope"></i></div>
          <h3>Rendez-vous médicaux</h3>
          <p>Médecin généraliste, spécialiste, kiné, CHU Timone, Hôpital Nord. Attente sur place possible.</p>
        </div>
      </div>

      <div class="col">
        <div class="service-card">
          <div class="icon"><i class="fas fa-umbrella-beach"></i></div>
          <h3>Promenades bord de mer</h3>
          <p>Corniche Kennedy, Plage du Prado, Parc Borély. Profitez du soleil marseillais en toute sérénité.</p>
        </div>
      </div>

      <div class="col">
        <div class="service-card">
          <div class="icon"><i class="fas fa-church"></i></div>
          <h3>Visites cimetière & famille</h3>
          <p>Cimetière Saint-Pierre, Mazargues, visites en famille. Ponctualité et discrétion garanties.</p>
        </div>
      </div>

      <div class="col">
        <div class="service-card">
          <div class="icon"><i class="fas fa-building"></i></div>
          <h3>Sorties EHPAD & maison de retraite</h3>
          <p>Conventions possibles avec les établissements. Facturation mensuelle disponible pour les EHPAD.</p>
        </div>
      </div>

      <div class="col">
        <div class="service-card">
          <div class="icon"><i class="fas fa-calendar-check"></i></div>
          <h3>Mise à disposition à la journée</h3>
          <p>Votre chauffeur personnel pour toute une journée. Idéal pour les événements familiaux.</p>
        </div>
      </div>

    </div>
  </div>
</section>

{# ── Garanties ─────────────────────────────────────────────────────── #}
<section class="zen-section zen-section-alt">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-5 mb-4 mb-lg-0">
        <h2 class="zen-section-title">Un service pensé pour le confort des seniors</h2>
        <p class="text-muted mb-4">Nous formons nos chauffeurs à l'accompagnement des personnes âgées et à mobilité réduite.</p>
        <a href="tel:+33674039694" class="btn btn-lg fw-bold px-4" style="background:var(--zen-orange);color:white;border-radius:50px;">
          <i class="bi bi-telephone-fill me-2"></i>Appeler le 06 74 03 96 94
        </a>
      </div>
      <div class="col-lg-7">
        <div class="guarantee-badge">
          <div class="icon"><i class="fas fa-hands-helping"></i></div>
          <div><strong>Aide à la montée et descente du véhicule</strong><br><small class="text-muted">Le chauffeur vous accompagne à chaque étape.</small></div>
        </div>
        <div class="guarantee-badge">
          <div class="icon"><i class="fas fa-clock"></i></div>
          <div><strong>Ponctualité garantie</strong><br><small class="text-muted">Votre chauffeur arrive à l'heure convenue, sans exception.</small></div>
        </div>
        <div class="guarantee-badge">
          <div class="icon"><i class="fas fa-volume-down"></i></div>
          <div><strong>Conduite douce et apaisante</strong><br><small class="text-muted">Pas de freinage brusque, musique discrète, conversation respectueuse.</small></div>
        </div>
        <div class="guarantee-badge">
          <div class="icon"><i class="fas fa-mobile-alt"></i></div>
          <div><strong>Réservation simple par téléphone</strong><br><small class="text-muted">Pas besoin d'application. Un appel suffit : 06 74 03 96 94.</small></div>
        </div>
        <div class="guarantee-badge">
          <div class="icon"><i class="fas fa-file-invoice"></i></div>
          <div><strong>Conventions & facturation EHPAD</strong><br><small class="text-muted">Nous établissons des conventions avec les établissements médico-sociaux.</small></div>
        </div>
      </div>
    </div>
  </div>
</section>

{# ── CTA final ─────────────────────────────────────────────────────── #}
<section style="background:var(--zen-orange);color:white;padding:60px 0;text-align:center;">
  <div class="container">
    <h2 style="font-weight:700;font-size:1.8rem;">Réservez un taxi senior à Marseille</h2>
    <p style="opacity:.9;margin-bottom:28px;">Disponible 7j/7 — Appelez ou envoyez un WhatsApp</p>
    <div class="d-flex flex-wrap justify-content-center gap-3">
      <a href="tel:+33674039694" class="btn btn-light btn-lg fw-bold px-5" style="color:var(--zen-orange);border-radius:50px;">
        <i class="bi bi-telephone-fill me-2"></i>06 74 03 96 94
      </a>
      <a href="{{ path('app_taxi_marseille') }}#reserver" class="btn btn-outline-light btn-lg fw-bold px-5" style="border-radius:50px;">
        Réserver en ligne
      </a>
    </div>
  </div>
</section>

{% endblock %}
