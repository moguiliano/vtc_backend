{% block jsonld %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "TaxiService",
  "name": "ZenCAR — Transport Seniors Marseille",
  "url": "https://dzencar.fr/transport-seniors-marseille",
  "telephone": "+33674039694",
  "description": "Service de transport et d'accompagnement pour personnes âgées à Marseille. Courses, rendez-vous médicaux, promenades, conventions EHPAD.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Marseille",
    "addressRegion": "Provence-Alpes-Côte d'Azur",
    "addressCountry": "FR"
  },
  "areaServed": {"@type": "City", "name": "Marseille"}
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Le chauffeur aide-t-il à monter et descendre du véhicule ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, systématiquement. Nos chauffeurs sont formés à l'accompagnement des personnes âgées et à mobilité réduite. Ils vous prennent en charge à votre porte, vous aident à vous installer confortablement et restent à votre disposition pendant toute la durée du trajet."
      }
    },
    {
      "@type": "Question",
      "name": "Comment réserver un transport senior à Marseille ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La réservation se fait par téléphone au 06 74 03 96 94 ou par WhatsApp. Aucune application n'est nécessaire. Vous pouvez aussi réserver à l'avance pour les rendez-vous médicaux, sorties EHPAD ou déplacements planifiés."
      }
    },
    {
      "@type": "Question",
      "name": "Proposez-vous des conventions avec les EHPAD ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui. Nous établissons des conventions avec les établissements médico-sociaux (EHPAD, maisons de retraite, résidences seniors). La facturation peut être mensuelle. Contactez-nous par téléphone ou via le formulaire de contact pour discuter des modalités."
      }
    },
    {
      "@type": "Question",
      "name": "Peut-on réserver pour accompagner un parent âgé ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolument. Beaucoup de familles nous contactent pour organiser les déplacements réguliers de leurs proches âgés (médecin, courses, visites). Le chauffeur assure la prise en charge de porte à porte et peut vous envoyer une confirmation d'arrivée si vous le souhaitez."
      }
    },
    {
      "@type": "Question",
      "name": "Intervenez-vous dans toute la ville de Marseille ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, nous couvrons l'ensemble des arrondissements de Marseille ainsi que les communes proches (Aubagne, Aix-en-Provence, Cassis, La Ciotat). Aucun supplément selon le quartier — le tarif est fixé à la réservation."
      }
    }
  ]
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://dzencar.fr/"},
    {"@type": "ListItem", "position": 2, "name": "Taxi Marseille", "item": "https://dzencar.fr/taxi-marseille"},
    {"@type": "ListItem", "position": 3, "name": "Transport Seniors", "item": "https://dzencar.fr/transport-seniors-marseille"}
  ]
}
</script>
{% endblock %}

