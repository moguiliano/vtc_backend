{% set bypass_otp = is_granted('ROLE_ADMIN') or is_granted('ROLE_REGULATEUR') %}

<div id="tab3" class="tab-content">
	<div style="text-align: left; margin-bottom: 16px;">
		<button type="button" class="nav-main-btn back-btn" onclick="UI.switchToTab('tab2')">Retour</button>
	</div>
	<div class="general-container">
		<h2 style="color: white;">Récapitulatif</h2>
		<ul style="color: #ccc; line-height: 1.6;">
			<li>
				<strong>Départ :</strong>
				<span id="recap_depart"></span>
			</li>
			<li>
				<strong>Arrivée :</strong>
				<span id="recap_arrivee"></span>
			</li>
			<li>
				<strong>Arrêt :</strong>
				<span id="recap_stop"></span>
			</li>
			<li>
				<strong>Siège bébé :</strong>
				<span id="recap_siege"></span>
			</li>
			<li>
				<strong>Type de véhicule :</strong>
				<span id="recap_type"></span>
			</li>
		</ul>

		<div id="recapitulatif-trajet" class="text-white text-sm my-2"></div>
		<div id="recap_prix_list" class="text-white mt-3"></div>

		<div id="guest-verification-section" class="mt-4">
			<h5 class="text-white">Informations client</h5>

			{# ── Prénom ── #}
			<div class="form-group mt-3">
				<label for="prenom" class="text-white">Prénom</label>
				<input type="text" id="prenom" name="prenom" class="form-control" autocomplete="given-name" required>
			</div>

			{# ── Téléphone + OTP ── #}
			{% include "./reservation/outilsReservation/phone.html.twig" %}

			{# ── Informations complémentaires ── #}
			<div class="form-group mt-4">
				<label for="infosComplementaires" class="text-white">
					Informations complémentaires <small class="text-muted">(optionnel)</small>
				</label>
				<textarea id="infosComplementaires" name="informationsComplementaires"
						  class="form-control" rows="3" maxlength="500"
						  placeholder="Nombre de bagages, instructions spéciales, remarques…"
						  style="background:#1e2130;color:#fff;border-color:rgba(255,255,255,.2);"></textarea>
				<small class="d-flex justify-content-end mt-1" style="color:rgba(255,255,255,.4);">
					<span id="infosCharCount">0</span>/500
				</small>
			</div>

			{# ── Mode de règlement ── #}
			<div class="form-group mt-4">
				<label class="text-white d-block mb-2">Mode de règlement</label>
				<div class="d-flex gap-2 flex-wrap">
					<input type="radio" name="modeReglement" id="mr_carte" value="carte_bancaire" class="btn-check" checked autocomplete="off">
					<label for="mr_carte" class="btn btn-outline-light">
						<i class="bi bi-credit-card me-1"></i>Carte bancaire
					</label>

					<input type="radio" name="modeReglement" id="mr_especes" value="especes" class="btn-check" autocomplete="off">
					<label for="mr_especes" class="btn btn-outline-light">
						<i class="bi bi-cash-coin me-1"></i>Espèces
					</label>
				</div>
			</div>

			{# ── OTP (caché si admin/régulateur) ── #}
			{% if bypass_otp %}
			<div class="alert mt-4" style="background:rgba(255,193,7,.1);border:1px solid rgba(255,193,7,.3);color:#ffc107;border-radius:10px;font-size:.88rem;">
				<i class="bi bi-shield-check me-2"></i>Vérification OTP désactivée — réservation en mode régulateur.
			</div>
			{% endif %}

		</div>

		<button id="confirmReservationBtn"
				class="btn btn-success mt-4"
				data-reservation-id="{{ reservation is defined and reservation ? reservation.id : '' }}"
				data-bypass-otp="{{ bypass_otp ? '1' : '0' }}"
				{% if not bypass_otp %}disabled{% endif %}>
			✅ Réserver maintenant
		</button>

	</div>
</div>

{# ── Auto-switch to Tab3 when reservation was just created ── #}
{% if show_tab3 is defined and show_tab3 %}
<script>
document.addEventListener('DOMContentLoaded', function () {
	if (window.UI && typeof window.UI.switchToTab === 'function') {
		window.UI.switchToTab('tab3');
	}
});
</script>
{% endif %}

<script>
(function () {
	// ── helpers ──
	function $(sel) { return document.querySelector(sel); }

	function getFirstName() {
		const el = $('#prenom') || $('#guestFirstName') || $('input[name="prenom"]');
		return el ? el.value.trim() : '';
	}

	function normalizeFrPhone(raw) {
		const digits = (raw || '').replace(/[^\d+]/g, '');
		if (/^\+/.test(digits)) return digits;
		if (/^0\d{9}$/.test(digits)) return '+33' + digits.slice(1);
		return digits;
	}

	function getFullPhone() {
		const input = $('#guestPhone') || $('input[type="tel"]');
		if (!input) return '';
		try {
			const iti = window.intlTelInputGlobals && window.intlTelInputGlobals.getInstance(input);
			if (iti) {
				if (typeof iti.isValidNumber === 'function' && !iti.isValidNumber()) return '';
				if (typeof iti.getNumber === 'function') return iti.getNumber();
			}
		} catch (e) {}
		return normalizeFrPhone(input.value.trim());
	}

	// ── character counter ──
	const infosArea = document.getElementById('infosComplementaires');
	const infosCount = document.getElementById('infosCharCount');
	if (infosArea && infosCount) {
		infosArea.addEventListener('input', () => { infosCount.textContent = infosArea.value.length; });
	}

	// ── confirm button ──
	const btn = document.getElementById('confirmReservationBtn');
	if (!btn) return;

	const resId = btn.dataset.reservationId || '';
	if (!resId) return; // no reservation yet

	const bypassOtp = btn.dataset.bypassOtp === '1';

	btn.addEventListener('click', async () => {
		const prenom = getFirstName();
		const clientPhone = getFullPhone();
		const informationsComplementaires = (document.getElementById('infosComplementaires')?.value || '').trim();
		const modeReglement = (document.querySelector('input[name="modeReglement"]:checked')?.value) || 'carte_bancaire';

		if (!prenom) { alert('Merci de renseigner votre prénom.'); return; }
		if (!bypassOtp && !clientPhone) { alert('Merci de renseigner un numéro de téléphone valide.'); return; }

		btn.disabled = true;

		try {
			const resp = await fetch(`/reservation/${resId}/confirm`, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
				body: JSON.stringify({ prenom, clientPhone, informationsComplementaires, modeReglement, bypassOtp }),
			});

			const data = await resp.json();
			if (data.ok && data.redirect) {
				window.location.href = data.redirect;
			} else {
				alert(data.error || 'Erreur lors de la confirmation.');
				btn.disabled = false;
			}
		} catch (e) {
			alert('Impossible de confirmer la réservation pour le moment.');
			btn.disabled = false;
		}
	});
})();


document.addEventListener('DOMContentLoaded', function () {
	const countryCode = document.getElementById('countryCode');
	const guestPhone  = document.getElementById('guestPhone');
	const sendOtpBtn  = document.getElementById('sendOtpBtn');
	const otpField    = document.getElementById('otpField');
	const otpInput    = document.getElementById('otpInput');
	const otpFeedback = document.getElementById('otpFeedback');
	const confirmBtn  = document.getElementById('confirmReservationBtn');

	const bypassOtp = confirmBtn?.dataset?.bypassOtp === '1';

	// Hide OTP section entirely when bypassed
	if (bypassOtp) {
		if (sendOtpBtn) sendOtpBtn.style.display = 'none';
		if (otpField)   otpField.style.display   = 'none';
		// Button already enabled via template (no `disabled` attr when bypass_otp)
		return;
	}

	function getFullPhoneNumber() {
		if (!guestPhone || !countryCode) return '';
		let number = guestPhone.value.trim();
		if (number.startsWith('0')) number = number.substring(1);
		return countryCode.value + number;
	}

	if (sendOtpBtn) {
		sendOtpBtn.addEventListener('click', function () {
			const phone = getFullPhoneNumber();
			if (!phone || phone.length < 6) { alert("Merci de saisir un numéro de téléphone valide."); return; }

			fetch('/otp/send', {
				method: 'POST',
				headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
				body: `phone=${encodeURIComponent(phone)}`,
			}).then(res => res.json()).then(data => {
				if (data.status === 'sent') {
					otpField.classList.remove('d-none');
					otpFeedback.innerText = "📲 Un code a été envoyé par SMS. Veuillez le saisir ci-dessous.";
				} else {
					otpFeedback.innerText = "❌ Une erreur est survenue lors de l'envoi du code.";
				}
			}).catch(() => { otpFeedback.innerText = "❌ Une erreur réseau est survenue."; });
		});
	}

	otpInput?.addEventListener('input', () => {
		const code  = otpInput.value.trim();
		const phone = getFullPhoneNumber();

		if (code.length === 6) {
			fetch('/otp/verify', {
				method: 'POST',
				headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
				body: `phone=${encodeURIComponent(phone)}&code=${encodeURIComponent(code)}`,
			}).then(res => res.json()).then(data => {
				if (data.valid) {
					otpFeedback.innerText = "✅ Vérification réussie. Vous pouvez réserver.";
					confirmBtn.disabled = false;
				} else {
					otpFeedback.innerText = "❌ Code incorrect. Réessayez.";
					confirmBtn.disabled = true;
				}
			}).catch(() => {
				otpFeedback.innerText = "❌ Impossible de vérifier le code. Problème réseau.";
				confirmBtn.disabled = true;
			});
		}
	});
});
</script>
