{% extends '@EasyAdmin/crud/index.html.twig' %}

{% block head_stylesheets %}
    {{ parent() }}
    <style>
        .contact-unread td {
            font-weight: 700 !important;
            background: rgba(255, 86, 48, 0.07) !important;
        }
    </style>
{% endblock %}

{% block main %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('table tbody tr').forEach(function (row) {
                const boolCell = row.querySelector('.field-boolean');
                if (!boolCell) return;
                // EasyAdmin affiche un SVG vert (lu) ou rouge/gris (non lu)
                const isUnread = boolCell.querySelector('.text-danger, [data-icon="times"], .fa-times') !== null
                    || boolCell.innerHTML.includes('text-danger')
                    || boolCell.innerHTML.includes('rgb(220')
                    || boolCell.innerText.trim() === 'Non';
                if (isUnread) row.classList.add('contact-unread');
            });
        });
    </script>
{% endblock %}
