{% extends '@EasyAdmin/crud/index.html.twig' %}

{% block head_stylesheets %}
    {{ parent() }}
    <style>
        /* Ligne non lue = fond légèrement coloré + texte gras */
        table.datagrid tbody tr[data-id] td:first-child ~ td {
            font-weight: normal;
        }
        .contact-unread td {
            font-weight: 600 !important;
            background: rgba(255, 86, 48, 0.06) !important;
        }
        .contact-unread td:first-child::before {
            content: '● ';
            color: #ff5630;
            font-size: 10px;
        }
        .badge-unread {
            background: #ff5630;
            color: white;
            border-radius: 10px;
            padding: 2px 7px;
            font-size: 11px;
            margin-left: 6px;
        }
    </style>
{% endblock %}

{% block content %}
    {{ parent() }}
{% endblock %}

{% block page_title %}
    Messages reçus
    {% set unread = entities | filter(e => not e.instance.isRead) | length %}
    {% if unread > 0 %}
        <span class="badge-unread">{{ unread }} non lu{{ unread > 1 ? 's' : '' }}</span>
    {% endif %}
{% endblock %}

{% block main %}
    <script>
        // Marquer les lignes non lues après le rendu
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('table.datagrid tbody tr').forEach(function (row) {
                const badge = row.querySelector('.field-boolean .badge, .field-boolean svg');
                // Si l'icône booléenne indique "non lu" (false = croix / grisé)
                if (badge && (badge.classList.contains('badge-danger') || badge.querySelector('.text-danger'))) {
                    row.classList.add('contact-unread');
                }
                // Détection via la couleur de l'icône SVG EasyAdmin
                const svg = row.querySelector('.field-boolean svg');
                if (svg && svg.closest('td') && svg.getAttribute('fill') === 'none') {
                    const stroke = svg.style.color || getComputedStyle(svg).color;
                    if (stroke && stroke.includes('rgb(220')) {
                        row.classList.add('contact-unread');
                    }
                }
            });

            // Méthode fiable : chercher l'icône fa-times ou la couleur rouge/grise
            document.querySelectorAll('table.datagrid tbody tr').forEach(function (row) {
                const boolCell = row.querySelector('.field-boolean');
                if (boolCell) {
                    const text = boolCell.innerText.trim().toLowerCase();
                    if (text === 'non' || text === 'no' || text === 'false' || boolCell.querySelector('.text-danger, .fa-times, [color="danger"]')) {
                        row.classList.add('contact-unread');
                    }
                }
            });
        });
    </script>
    {{ parent() }}
{% endblock %}
