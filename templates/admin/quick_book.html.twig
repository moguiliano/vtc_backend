<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>Réservation rapide — ZenCAR Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root { --zen-orange: #ff5630; }
        body {
            margin: 0;
            min-height: 100vh;
            background: linear-gradient(135deg, #0d1117 0%, #1a2332 100%);
            display: flex;
            align-items: flex-start;
            justify-content: center;
            padding: 2rem 1rem;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
        .card {
            background: #1a1d27;
            border: 1px solid rgba(255,255,255,.08);
            border-radius: 20px;
            padding: 2.5rem 2rem;
            width: 100%;
            max-width: 560px;
            box-shadow: 0 24px 64px rgba(0,0,0,.5);
        }
        .brand { text-align:center; margin-bottom:1.8rem; }
        .brand span { font-size:1.8rem; font-weight:800; color:var(--zen-orange); }
        .brand small { display:block; color:rgba(255,255,255,.4); font-size:.72rem; letter-spacing:2px; text-transform:uppercase; margin-top:3px; }
        h1 { color:white; font-size:1.15rem; font-weight:600; text-align:center; margin-bottom:1.8rem; }
        .form-label { color:rgba(255,255,255,.7); font-size:.84rem; margin-bottom:.35rem; }
        .form-control, .form-select {
            background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.1);
            border-radius:10px; color:white; padding:11px 14px; font-size:.93rem;
        }
        .form-control:focus, .form-select:focus {
            background:rgba(255,255,255,.09); border-color:var(--zen-orange);
            box-shadow:0 0 0 3px rgba(255,86,48,.15); color:white; outline:none;
        }
        .form-control::placeholder { color:rgba(255,255,255,.25); }
        .form-select option { background:#1a1d27; color:white; }
        .forfait-card {
            background:rgba(255,86,48,.07); border:1px solid rgba(255,86,48,.2);
            border-radius:12px; padding:1rem 1.2rem; margin-bottom:.6rem;
            cursor:pointer; transition:all .2s;
        }
        .forfait-card:hover, .forfait-card.selected {
            background:rgba(255,86,48,.18); border-color:var(--zen-orange);
        }
        .forfait-card input[type=radio] { display:none; }
        .forfait-label { color:rgba(255,255,255,.8); font-size:.9rem; }
        .forfait-prix { color:var(--zen-orange); font-weight:700; font-size:1.1rem; }
        .btn-save {
            width:100%; background:var(--zen-orange); color:white; border:none;
            border-radius:50px; padding:14px; font-size:1rem; font-weight:700;
            cursor:pointer; transition:opacity .2s; margin-top:.6rem;
        }
        .btn-save:hover { opacity:.9; }
        .alert-error { background:rgba(220,53,69,.15); border:1px solid rgba(220,53,69,.3); border-radius:10px; color:#ff8080; padding:11px 15px; font-size:.86rem; margin-bottom:1.2rem; }
        .back-link { display:block; text-align:center; margin-top:1.2rem; color:rgba(255,255,255,.35); font-size:.82rem; text-decoration:none; transition:color .2s; }
        .back-link:hover { color:var(--zen-orange); }
        .divider { border-color:rgba(255,255,255,.08); margin:1.4rem 0; }
        .section-title { color:rgba(255,255,255,.45); font-size:.75rem; text-transform:uppercase; letter-spacing:1.5px; margin-bottom:.8rem; }
    </style>
</head>
<body>
<div class="card">
    <div class="brand">
        <span>ZenCAR</span>
        <small>Réservation rapide</small>
    </div>

    <h1><i class="bi bi-lightning-fill me-2" style="color:var(--zen-orange);"></i>Créer une réservation forfait</h1>

    {% if error %}
    <div class="alert-error"><i class="bi bi-exclamation-circle-fill me-2"></i>{{ error }}</div>
    {% endif %}

    <form method="post">
        <p class="section-title">1. Choisir le forfait</p>
        {% for forfait in forfaits %}
        <label class="forfait-card d-flex justify-content-between align-items-center">
            <input type="radio" name="forfaitId" value="{{ forfait.id }}" required>
            <span class="forfait-label">
                <i class="bi bi-geo-alt-fill me-1" style="color:var(--zen-orange);"></i>
                {{ forfait.depart }} → {{ forfait.arrivee }}
                {% if forfait.distance %}<span style="color:rgba(255,255,255,.35);font-size:.8rem;"> · {{ forfait.distance }} km</span>{% endif %}
            </span>
            <span class="forfait-prix">{{ forfait.prix }} €</span>
        </label>
        {% else %}
        <p style="color:rgba(255,255,255,.4);font-size:.88rem;">Aucun forfait actif. <a href="{{ path('admin') }}" style="color:var(--zen-orange);">Créer un forfait</a></p>
        {% endfor %}

        <hr class="divider">
        <p class="section-title">2. Informations client</p>

        <div class="mb-3">
            <label class="form-label">Prénom *</label>
            <input type="text" name="prenom" class="form-control" placeholder="Prénom du client" required>
        </div>
        <div class="mb-3">
            <label class="form-label">Téléphone *</label>
            <input type="tel" name="telephone" class="form-control" placeholder="06 XX XX XX XX" inputmode="tel" pattern="[0-9+\s().-]*" required>
        </div>

        <hr class="divider">
        <p class="section-title">3. Heure de prise en charge</p>
        <div class="mb-3 d-flex gap-2">
            <button type="button" class="btn flex-fill admin-offset active" data-offset="0"
                    style="border-radius:10px;border:1px solid rgba(255,255,255,.2);color:white;background:rgba(255,255,255,.15);">
                <i class="bi bi-clock me-1"></i>Maintenant
            </button>
            <button type="button" class="btn flex-fill admin-offset" data-offset="-10"
                    style="border-radius:10px;border:1px solid rgba(255,255,255,.2);color:white;background:rgba(255,255,255,.04);">
                <i class="bi bi-clock-history me-1"></i>- 10 min
            </button>
        </div>
        <div class="mt-2 text-center" style="color:#ff5630;font-size:.95rem;font-weight:600;">
            <i class="bi bi-alarm me-1"></i>Prise en charge à <span id="adminHeureAffichee"></span>
        </div>
        <input type="hidden" name="offsetMinutes" id="adminOffsetInput" value="0">

        <hr class="divider">
        <p class="section-title">4. Mode de règlement</p>

        <div class="mb-3">
            <select name="modeReglement" class="form-select">
                <option value="carte_bancaire">Carte bancaire</option>
                <option value="especes">Espèces</option>
            </select>
        </div>

        <button class="btn-save" type="submit">
            <i class="bi bi-check-lg me-2"></i>Créer la réservation
        </button>
    </form>

    <a href="{{ path('admin') }}" class="back-link">
        <i class="bi bi-arrow-left me-1"></i>Retour au tableau de bord
    </a>
</div>
<script>
document.querySelectorAll('.forfait-card').forEach(card => {
    card.addEventListener('click', () => {
        document.querySelectorAll('.forfait-card').forEach(c => c.classList.remove('selected'));
        card.classList.add('selected');
        card.querySelector('input[type=radio]').checked = true;
    });
});

function updateAdminHeure() {
    const offset = parseInt(document.getElementById('adminOffsetInput').value, 10) || 0;
    const d = new Date(Date.now() + offset * 60000);
    const h = String(d.getHours()).padStart(2, '0');
    const m = String(d.getMinutes()).padStart(2, '0');
    const el = document.getElementById('adminHeureAffichee');
    if (el) el.textContent = h + 'h' + m;
}

document.querySelectorAll('.admin-offset').forEach(btn => {
    btn.addEventListener('click', () => {
        document.querySelectorAll('.admin-offset').forEach(b => {
            b.classList.remove('active');
            b.style.background = 'rgba(255,255,255,.04)';
        });
        btn.classList.add('active');
        btn.style.background = 'rgba(255,255,255,.15)';
        document.getElementById('adminOffsetInput').value = btn.dataset.offset;
        updateAdminHeure();
    });
});

updateAdminHeure();
</script>
</body>
</html>
