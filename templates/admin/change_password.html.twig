<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>Changer mon mot de passe — ZenCAR Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root { --zen-orange: #ff5630; }
        body {
            margin: 0;
            min-height: 100vh;
            background: linear-gradient(135deg, #0d1117 0%, #1a2332 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
        .card {
            background: #1a1d27;
            border: 1px solid rgba(255,255,255,.08);
            border-radius: 20px;
            padding: 2.5rem 2rem;
            width: 100%;
            max-width: 440px;
            box-shadow: 0 24px 64px rgba(0,0,0,.5);
        }
        .brand { text-align:center; margin-bottom:1.8rem; }
        .brand span { font-size:1.8rem; font-weight:800; color:var(--zen-orange); }
        .brand small { display:block; color:rgba(255,255,255,.4); font-size:.72rem; letter-spacing:2px; text-transform:uppercase; margin-top:3px; }
        h1 { color:white; font-size:1.1rem; font-weight:600; text-align:center; margin-bottom:1.6rem; }
        .form-label { color:rgba(255,255,255,.7); font-size:.84rem; margin-bottom:.35rem; }
        .input-wrap { position:relative; margin-bottom:1.1rem; }
        .input-wrap i.icon { position:absolute; left:13px; top:50%; transform:translateY(-50%); color:rgba(255,255,255,.3); }
        .form-control {
            background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.1);
            border-radius:10px; color:white; padding:11px 13px 11px 38px; font-size:.93rem;
        }
        .form-control:focus { background:rgba(255,255,255,.09); border-color:var(--zen-orange); box-shadow:0 0 0 3px rgba(255,86,48,.15); color:white; outline:none; }
        .form-control::placeholder { color:rgba(255,255,255,.2); }
        .btn-save {
            width:100%; background:var(--zen-orange); color:white; border:none;
            border-radius:50px; padding:13px; font-size:1rem; font-weight:700;
            cursor:pointer; transition:opacity .2s; margin-top:.4rem;
        }
        .btn-save:hover { opacity:.9; }
        .alert-error { background:rgba(220,53,69,.15); border:1px solid rgba(220,53,69,.3); border-radius:10px; color:#ff8080; padding:11px 15px; font-size:.86rem; margin-bottom:1.1rem; }
        .alert-success { background:rgba(76,175,80,.15); border:1px solid rgba(76,175,80,.3); border-radius:10px; color:#81c784; padding:11px 15px; font-size:.86rem; margin-bottom:1.1rem; }
        .back-link { display:block; text-align:center; margin-top:1.2rem; color:rgba(255,255,255,.35); font-size:.82rem; text-decoration:none; transition:color .2s; }
        .back-link:hover { color:var(--zen-orange); }
    </style>
</head>
<body>
<div class="card">
    <div class="brand">
        <span>ZenCAR</span>
        <small>Administration</small>
    </div>

    <h1><i class="bi bi-key-fill me-2" style="color:var(--zen-orange);"></i>Changer mon mot de passe</h1>

    {% if error %}
    <div class="alert-error"><i class="bi bi-exclamation-circle-fill me-2"></i>{{ error }}</div>
    {% endif %}

    {% if success %}
    <div class="alert-success"><i class="bi bi-check-circle-fill me-2"></i>Mot de passe modifié avec succès !</div>
    {% endif %}

    <form method="post">
        <div class="input-wrap">
            <label class="form-label">Mot de passe actuel</label>
            <i class="bi bi-lock-fill icon"></i>
            <input type="password" name="current_password" class="form-control" placeholder="••••••••" required>
        </div>
        <div class="input-wrap">
            <label class="form-label">Nouveau mot de passe</label>
            <i class="bi bi-lock icon"></i>
            <input type="password" name="new_password" class="form-control" placeholder="8 caractères minimum" required minlength="8">
        </div>
        <div class="input-wrap">
            <label class="form-label">Confirmer le nouveau mot de passe</label>
            <i class="bi bi-lock icon"></i>
            <input type="password" name="confirm_password" class="form-control" placeholder="••••••••" required>
        </div>
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('change_password') }}">
        <button class="btn-save" type="submit">
            <i class="bi bi-check-lg me-2"></i>Enregistrer
        </button>
    </form>

    <a href="{{ path('admin') }}" class="back-link">
        <i class="bi bi-arrow-left me-1"></i>Retour au tableau de bord
    </a>
</div>
</body>
</html>
