{% block jsonld %}
<script type="application/ld+json">
[
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://dzencar.fr/" },
      { "@type": "ListItem", "position": 2, "name": "Taxi Marseille", "item": "https://dzencar.fr/taxi-marseille" },
      { "@type": "ListItem", "position": 3, "name": "Gare Saint-Charles" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "TaxiService",
    "name": "ZenCAR — Taxi & VTC Gare Saint-Charles Marseille",
    "url": "https://dzencar.fr/taxi-gare-saint-charles",
    "telephone": "+33674039694",
    "description": "Service Taxi et VTC pour la Gare Saint-Charles de Marseille. Taxi au compteur tarifs officiels Ville de Marseille, VTC prix fixe affiché avant réservation.",
    "areaServed": [
      { "@type": "TrainStation", "name": "Gare de Marseille-Saint-Charles" },
      { "@type": "City", "name": "Marseille" }
    ],
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
      "opens": "05:00",
      "closes": "23:59"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Quel est le tarif taxi depuis la Gare Saint-Charles ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Le tarif taxi est fixé par le compteur selon les tarifs officiels réglementés par la Ville de Marseille. Pour un VTC, le prix fixe est calculé et affiché avant votre confirmation de réservation."
        }
      },
      {
        "@type": "Question",
        "name": "Où se trouvent les taxis à la Gare Saint-Charles ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "La station de taxis se situe à la sortie principale de la Gare Saint-Charles, en bas du grand escalier monumental, côté Boulevard d'Athènes."
        }
      },
      {
        "@type": "Question",
        "name": "Peut-on réserver un taxi pour la Gare Saint-Charles à l'avance ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Oui, vous pouvez réserver à l'avance via notre formulaire de réservation en ligne ou par téléphone au 06 74 03 96 94. La réservation à l'avance est recommandée pour les trains matinaux."
        }
      },
      {
        "@type": "Question",
        "name": "ZenCAR dessert-il toutes les destinations depuis la Gare Saint-Charles ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Oui, nous assurons les transferts depuis et vers la Gare Saint-Charles vers toutes les destinations : centre-ville, aéroport, hôtels, quartiers résidentiels et alentours de Marseille."
        }
      }
    ]
  }
]
</script>
{% endblock %}

