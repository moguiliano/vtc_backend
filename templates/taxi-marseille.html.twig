{% extends 'base.html.twig' %}

{% block title %}Taxi Marseille — Disponible en 5 min | ZenCAR Taxi & VTC{% endblock %}

{% block meta %}
<meta name="description" content="Commandez un taxi à Marseille en 5 minutes. Taxi ou VTC au choix, prise en charge garantie, tarif affiché avant réservation. Aéroport, gare, calanques, seniors. Appelez le 06 74 03 96 94." />
<meta name="robots" content="index, follow" />
{% endblock %}

{% block canonical %}
<link rel="canonical" href="https://dzencar.fr/taxi-marseille" />
{% endblock %}

{% block og_title %}Taxi Marseille — Disponible en 5 min | ZenCAR{% endblock %}
{% block og_description %}Commandez un taxi à Marseille en 5 min. Tarif fixe affiché, prise en charge garantie, +300 chauffeurs locaux. Aéroport, gare, seniors. 06 74 03 96 94{% endblock %}
{% block og_url %}https://dzencar.fr/taxi-marseille{% endblock %}

{% block jsonld %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "TaxiService",
  "name": "ZenCAR — Taxi & VTC Marseille",
  "url": "https://dzencar.fr",
  "telephone": "+33674039694",
  "description": "Plateforme de mise en relation Taxi & VTC à Marseille. Prise en charge garantie, tarif affiché, chauffeurs locaux.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Marseille",
    "addressRegion": "Provence-Alpes-Côte d'Azur",
    "addressCountry": "FR"
  },
  "areaServed": [
    {"@type": "City", "name": "Marseille"},
    {"@type": "City", "name": "Aix-en-Provence"},
    {"@type": "Place", "name": "Aéroport Marseille-Provence"}
  ],
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
    "opens": "06:00",
    "closes": "23:00"
  },
  "priceRange": "€€"
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Comment commander un taxi à Marseille avec ZenCAR ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Réservez sur dzencar.fr ou appelez le 06 74 03 96 94. Votre taxi arrive en 5 à 10 minutes avec SMS de confirmation incluant le nom et la plaque du chauffeur."
      }
    },
    {
      "@type": "Question",
      "name": "ZenCAR propose-t-il des taxis ET des VTC à Marseille ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, ZenCAR est la seule plateforme à Marseille qui regroupe taxis et VTC sur une interface unique. Vous choisissez votre type de véhicule selon vos besoins et votre budget."
      }
    },
    {
      "@type": "Question",
      "name": "Quel est le tarif d'un taxi Marseille aéroport ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Le tarif est affiché avant confirmation sur dzencar.fr. Aucune surprise, aucun surge pricing. Le prix que vous voyez est le prix que vous payez."
      }
    },
    {
      "@type": "Question",
      "name": "ZenCAR propose-t-il un taxi pour personnes âgées à Marseille ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui. Accompagnement senior : courses, promenades bord de mer, rendez-vous médicaux, visites au cimetière. Chauffeurs patients, aide à la montée et descente. Conventions EHPAD disponibles."
      }
    }
  ]
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://dzencar.fr/"},
    {"@type": "ListItem", "position": 2, "name": "Taxi Marseille", "item": "https://dzencar.fr/taxi-marseille"}
  ]
}
</script>
{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<link rel="stylesheet" href="{{ asset('css/reservationStyles.css') }}">
<style>
  :root {
    --zen-green:      #1D9E75;
    --zen-green-dark: #0F6E56;
    --zen-bg-light:   #E1F5EE;
    --zen-dark:       #1A1A18;
    --zen-white:      #FEFEFE;
  }

  /* Hero */
  .zen-hero {
    background: linear-gradient(135deg, var(--zen-green-dark) 0%, var(--zen-green) 100%);
    padding: clamp(40px, 8vw, 80px) 0 clamp(32px, 6vw, 60px);
    color: var(--zen-white);
  }
  .zen-hero h1 { font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; }
  .zen-hero .badge-rapide {
    display: inline-block;
    background: rgba(255,255,255,0.2);
    border: 1px solid rgba(255,255,255,0.4);
    border-radius: 50px;
    padding: 6px 18px;
    font-size: .9rem;
    margin-bottom: 16px;
  }
  .zen-cta-tel {
    background: var(--zen-white);
    color: var(--zen-green-dark);
    font-weight: 700;
    border-radius: 50px;
    padding: 14px 32px;
    font-size: 1.1rem;
    text-decoration: none;
    display: inline-block;
    margin-top: 8px;
    transition: background .2s;
  }
  .zen-cta-tel:hover { background: var(--zen-bg-light); }

  /* Sections */
  .zen-section { padding: 60px 0; }
  .zen-section-alt { background: var(--zen-bg-light); }
  .zen-section-title {
    color: var(--zen-green-dark);
    font-weight: 700;
    font-size: clamp(1.1rem, 4vw, 1.6rem);
    margin-bottom: 8px;
  }
  .zen-section-subtitle { color: #555; margin-bottom: 36px; }

  /* Service cards */
  .zen-service-card {
    background: var(--zen-white);
    border-radius: 14px;
    padding: 24px 20px;
    height: 100%;
    border: 1px solid #e0f0e9;
    transition: box-shadow .2s, transform .2s;
  }
  .zen-service-card:hover {
    box-shadow: 0 8px 24px rgba(15,110,86,.12);
    transform: translateY(-4px);
  }
  .zen-service-card .icon {
    width: 48px; height: 48px;
    background: var(--zen-bg-light);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; color: var(--zen-green);
    margin-bottom: 14px;
  }
  .zen-service-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 6px; }
  .zen-service-card p  { font-size: .88rem; color: #666; margin: 0; }

  /* Différenciateurs */
  .zen-diff-item {
    display: flex; align-items: flex-start; gap: 14px;
    padding: 18px 0;
    border-bottom: 1px solid #e8f5f0;
  }
  .zen-diff-item:last-child { border-bottom: none; }
  .zen-diff-item .check {
    width: 36px; height: 36px; min-width: 36px;
    background: var(--zen-green);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: white; font-size: 1rem;
  }
  .zen-diff-item strong { display: block; font-size: 1rem; color: var(--zen-dark); }
  .zen-diff-item span   { font-size: .88rem; color: #666; }

  /* Zones */
  .zen-zone-badge {
    display: inline-block;
    background: var(--zen-white);
    border: 1.5px solid var(--zen-green);
    color: var(--zen-green-dark);
    border-radius: 50px;
    padding: 6px 16px;
    font-size: .88rem;
    font-weight: 600;
    margin: 5px 4px;
  }

  /* FAQ */
  .zen-faq .accordion-button {
    font-weight: 600;
    color: var(--zen-dark);
    background: var(--zen-white);
  }
  .zen-faq .accordion-button:not(.collapsed) {
    color: var(--zen-green-dark);
    background: var(--zen-bg-light);
    box-shadow: none;
  }
  .zen-faq .accordion-button::after {
    filter: hue-rotate(130deg);
  }
  .zen-faq .accordion-item {
    border: 1px solid #d8ede6;
    border-radius: 10px !important;
    margin-bottom: 10px;
    overflow: hidden;
  }

  /* CTA bannière */
  .zen-cta-banner {
    background: var(--zen-green-dark);
    color: var(--zen-white);
    padding: 50px 0;
    text-align: center;
  }
  .zen-cta-banner h2 { font-size: clamp(1.2rem, 4vw, 1.8rem); font-weight: 700; margin-bottom: 10px; }
  .zen-cta-banner p  { opacity: .85; margin-bottom: 24px; }

  /* Seniors highlight */
  .zen-seniors-card {
    background: linear-gradient(135deg, #fff8f0, #fff3e0);
    border: 2px solid #ff9800;
    border-radius: 16px;
    padding: 32px;
  }
  .zen-seniors-card h3 { color: #e65100; font-weight: 700; }

  /* Floating buttons */
  #floating-contact {
    position: fixed; bottom: 24px; right: 20px;
    display: flex; flex-direction: column; gap: 12px;
    z-index: 999;
  }
  .btn-call     { background: #1976d2; color: white; font-size: 1.3rem; width: 54px; height: 54px; display: flex; align-items: center; justify-content: center; }
  .btn-whatsapp { background: #25d366; color: white; font-size: 1.3rem; width: 54px; height: 54px; display: flex; align-items: center; justify-content: center; }

  /* Form section */
  .zen-form-section { background: var(--zen-dark); padding: 60px 0; }
  .zen-form-section .tabs .tab-button { color: #ccc; }
  .zen-form-section .tabs .tab-button.active { color: var(--zen-green); border-bottom-color: var(--zen-green); }

  /* ── Mobile CTA full-width ───────────────────── */
  @media (max-width: 480px) {
    .zen-hero .btn,
    .zen-hero .zen-cta-tel,
    .zen-cta-banner .btn,
    .zen-seniors-card .btn {
      width: 100%;
      text-align: center;
      display: block;
    }
    .zen-seniors-card { padding: 16px; }
    .zen-section { padding: 40px 0; }
  }
</style>
{% endblock %}

