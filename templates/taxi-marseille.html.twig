{% block jsonld %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "TaxiService",
  "name": "ZenCAR — Taxi & VTC Marseille",
  "url": "https://dzencar.fr",
  "telephone": "+33674039694",
  "description": "Plateforme de mise en relation Taxi & VTC à Marseille. Prise en charge garantie, tarif affiché, chauffeurs locaux.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Marseille",
    "addressRegion": "Provence-Alpes-Côte d'Azur",
    "addressCountry": "FR"
  },
  "areaServed": [
    {"@type": "City", "name": "Marseille"},
    {"@type": "City", "name": "Aix-en-Provence"},
    {"@type": "Place", "name": "Aéroport Marseille-Provence"}
  ],
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
    "opens": "06:00",
    "closes": "23:00"
  },
  "priceRange": "€€"
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Comment commander un taxi à Marseille avec ZenCAR ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Réservez sur dzencar.fr ou appelez le 06 74 03 96 94. Votre taxi arrive en 5 à 10 minutes avec SMS de confirmation incluant le nom et la plaque du chauffeur."
      }
    },
    {
      "@type": "Question",
      "name": "ZenCAR propose-t-il des taxis ET des VTC à Marseille ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, ZenCAR est la seule plateforme à Marseille qui regroupe taxis et VTC sur une interface unique. Vous choisissez votre type de véhicule selon vos besoins et votre budget."
      }
    },
    {
      "@type": "Question",
      "name": "Quel est le tarif d'un taxi Marseille aéroport ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Le tarif est affiché avant confirmation sur dzencar.fr. Aucune surprise, aucun surge pricing. Le prix que vous voyez est le prix que vous payez."
      }
    },
    {
      "@type": "Question",
      "name": "ZenCAR propose-t-il un taxi pour personnes âgées à Marseille ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui. Accompagnement senior : courses, promenades bord de mer, rendez-vous médicaux, visites au cimetière. Chauffeurs patients, aide à la montée et descente. Conventions EHPAD disponibles."
      }
    }
  ]
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://dzencar.fr/"},
    {"@type": "ListItem", "position": 2, "name": "Taxi Marseille", "item": "https://dzencar.fr/taxi-marseille"}
  ]
}
</script>
{% endblock %}

