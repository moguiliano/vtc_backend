<!DOCTYPE html>
<html lang="fr">
  <head>
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-WXJ6V2W4');</script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Permissions-Policy" content="geolocation=*">

    {# ── SEO ─────────────────────────────────────────────────────────── #}
    {% block meta %}
    <meta name="description" content="Taxi & VTC à Marseille en 5 minutes. Taxi au compteur tarifs officiels Ville de Marseille, VTC prix fixe affiché avant réservation. Aéroport, gare, calanques. Appelez le 06 74 03 96 94." />
    <meta name="robots" content="index, follow" />
    {% endblock %}

    {% block canonical %}
    <link rel="canonical" href="https://dzencar.fr/" />
    {% endblock %}

    {# ── Open Graph ───────────────────────────────────────────────────── #}
    {% block opengraph %}
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content="ZenCAR Taxi & VTC Marseille" />
    <meta property="og:title"       content="{% block og_title %}Taxi Marseille — ZenCAR Taxi & VTC{% endblock %}" />
    <meta property="og:description" content="{% block og_description %}Commandez un taxi à Marseille en 5 min. Tarif fixe, chauffeurs locaux, aéroport, gare, seniors. 06 74 03 96 94{% endblock %}" />
    <meta property="og:url"         content="{% block og_url %}https://dzencar.fr/{% endblock %}" />
    {% endblock %}

    {# ── JSON-LD (schemas structurés) ────────────────────────────────── #}
    {% block jsonld %}{% endblock %}

    {# ── Assets ───────────────────────────────────────────────────────── #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@17.0.19/build/css/intlTelInput.min.css" />
    <link href="{{ asset('build/app.css') }}" rel="stylesheet">
    <link rel="stylesheet" type="text/css" href="https://js.api.here.com/v3/3.1/mapsjs-ui.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('css/zencar.css') }}?v=3">
    <link rel="stylesheet" href="{{ asset('css/reservationStyles.css') }}?v=3">

    <title>{% block title %}Taxi & VTC Marseille — ZenCAR{% endblock %}</title>

    {% block stylesheets %}{% endblock %}
  </head>

  <body class="bg-light">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WXJ6V2W4"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    {% include 'partials/_navbar.html.twig' %}

    <!-- ✅ Boutons Appel / WhatsApp visibles sur toutes tailles d'écran -->
   
    <main>
      {% block body %}{% endblock %}
    </main>

    {% include 'partials/_footer.html.twig' %}

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
