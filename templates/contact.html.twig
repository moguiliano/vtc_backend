{% extends 'base.html.twig' %}

{% block title %}Contact — ZenCAR{% endblock %}

{% block body %}

{% include 'partials/_breadcrumb.html.twig' with { items: [
  { label: 'Accueil', url: path('app_home') },
  { label: 'Contact' }
]} %}

<section id="contact" class="container my-5">
  <h2 class="text-center mb-4" style="color:white;font-weight:700;font-size:2rem;">Contactez-nous</h2>
  <p class="text-center mb-5" style="color:#bbbbbb;">
    Une question ou une demande ? Contactez
    <span style="color:var(--zen-orange);font-weight:bold;">ZenCAR</span> facilement.
  </p>

  {% for message in app.flashes('success') %}
    <div class="alert alert-success text-center">{{ message }}</div>
  {% endfor %}

  <div class="row">

    {# ── Formulaire ──────────────────────────────────────────── #}
    <div class="col-md-6 mb-4">
      <div class="contact-box h-100">
        <h4>📧 Formulaire</h4>
        {{ form_start(form) }}
          <div class="mb-3">
            {{ form_label(form.name) }}
            {{ form_widget(form.name) }}
            {% if form_errors(form.name) %}
              <div class="form-error">{{ form_errors(form.name) }}</div>
            {% endif %}
          </div>
          <div class="mb-3">
            {{ form_label(form.email) }}
            {{ form_widget(form.email) }}
            {% if form_errors(form.email) %}
              <div class="form-error">{{ form_errors(form.email) }}</div>
            {% endif %}
          </div>
          <div class="mb-3">
            {{ form_label(form.phone) }}
            {{ form_widget(form.phone) }}
            {% if form_errors(form.phone) %}
              <div class="form-error">{{ form_errors(form.phone) }}</div>
            {% endif %}
          </div>
          <div class="mb-3">
            {{ form_label(form.message) }}
            {{ form_widget(form.message) }}
            {% if form_errors(form.message) %}
              <div class="form-error">{{ form_errors(form.message) }}</div>
            {% endif %}
          </div>
          <button type="submit" class="btn-zen w-100">Envoyer</button>
        {{ form_end(form) }}
      </div>
    </div>

    {# ── Appel + WhatsApp ────────────────────────────────────── #}
    <div class="col-md-6 mb-4 d-flex flex-column gap-4">
      <div class="contact-box h-100">
        <h4>📞 Appel
          <a href="tel:+33674039694" class="text-white fw-bold">+33 6 74 03 96 94</a>
        </h4>
        <p>Appelez-nous directement pour toute urgence ou réservation rapide.</p>
        <a href="tel:+33674039694" class="btn-call w-100 rounded-3 justify-content-center py-3">
          <i class="bi bi-telephone-fill me-2"></i>Appeler maintenant
        </a>
      </div>
      <div class="contact-box h-100">
        <h4>💬 WhatsApp</h4>
        <p>Discutez avec ZenCAR via WhatsApp en un clic.</p>
        <a href="https://wa.me/33674039694" target="_blank" class="btn-whatsapp w-100 rounded-3 justify-content-center py-3">
          <i class="bi bi-whatsapp me-2"></i>Envoyer un message
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  /* ── Styles spécifiques à la page contact ─── */
  #contact { color: #fff; }

  .contact-box {
    background: var(--zen-bg);
    border: 1px solid var(--zen-border);
    border-radius: 1rem;
    padding: clamp(1.25rem, 3vw, 2rem);
    box-shadow: 0 4px 12px rgba(0,0,0,.3);
    transition: transform .2s, box-shadow .2s;
    color: white;
  }
  .contact-box:hover {
    transform: translateY(-4px);
    box-shadow: 0 6px 16px rgba(0,0,0,.4);
  }
  .contact-box h4         { color: white; font-weight: 600; margin-bottom: 1rem; }
  .contact-box p,
  .contact-box label      { color: var(--zen-muted); }

  .contact-box .form-control {
    background: rgba(255,255,255,.03);
    color: white;
    border: 1px solid var(--zen-border);
    border-radius: .5rem;
    padding: .75rem;
  }
  .contact-box .form-control::placeholder { color: #888; }
  .contact-box .form-control:focus {
    background: rgba(255,255,255,.05);
    border-color: var(--zen-orange);
    box-shadow: 0 0 0 .2rem var(--zen-orange-dim);
    outline: none;
  }

  @media (max-width: 767px) {
    .contact-box { padding: 1.25rem 1rem; }
  }
</style>

{% endblock %}
