{% block stylesheets %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<style>
  /* ── Swiper ZenCAR — section Pourquoi ── */
  .zencar-why-swiper {
    padding: 8px 4px 48px !important;
    --swiper-theme-color: #ff5630;
    --swiper-navigation-size: 20px;
  }
  .zencar-why-swiper .swiper-slide { height: auto; }
  /* Override : step-box toujours visible dans le swiper (animation gérée par Swiper) */
  .zencar-why-swiper .step-box {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }
  .zencar-why-swiper .swiper-button-prev,
  .zencar-why-swiper .swiper-button-next {
    background: rgba(255,255,255,.08);
    border-radius: 50%;
    width: 38px; height: 38px;
    top: 42%;
  }
  .zencar-why-swiper .swiper-button-prev::after,
  .zencar-why-swiper .swiper-button-next::after { font-size: 13px; font-weight: 900; }
  .zencar-why-swiper .swiper-pagination-bullet { background: rgba(255,255,255,.3); opacity: 1; }
  .zencar-why-swiper .swiper-pagination-bullet-active { background: #ff5630; }
</style>
{% endblock %}

