<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>Connexion Admin — ZenCAR</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --zen-orange: #ff5630;
            --zen-dark:   #12141c;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            min-height: 100vh;
            background: linear-gradient(135deg, #0d1117 0%, #1a2332 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }

        .login-card {
            background: #1a1d27;
            border: 1px solid rgba(255,255,255,.08);
            border-radius: 20px;
            padding: 2.5rem 2rem;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 24px 64px rgba(0,0,0,.5);
        }

        .login-logo {
            text-align: center;
            margin-bottom: 2rem;
        }

        .login-logo span {
            font-size: 2rem;
            font-weight: 800;
            color: var(--zen-orange);
            letter-spacing: -1px;
        }

        .login-logo small {
            display: block;
            color: rgba(255,255,255,.4);
            font-size: .75rem;
            margin-top: 4px;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .login-title {
            color: white;
            font-size: 1.2rem;
            font-weight: 600;
            text-align: center;
            margin-bottom: 1.8rem;
        }

        .form-label {
            color: rgba(255,255,255,.7);
            font-size: .85rem;
            margin-bottom: .4rem;
        }

        .input-wrap {
            position: relative;
            margin-bottom: 1.2rem;
        }

        .input-wrap i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255,255,255,.3);
            font-size: 1rem;
        }

        .form-control {
            background: rgba(255,255,255,.06);
            border: 1px solid rgba(255,255,255,.1);
            border-radius: 10px;
            color: white;
            padding: 12px 14px 12px 40px;
            font-size: .95rem;
            transition: border-color .2s;
        }

        .form-control:focus {
            background: rgba(255,255,255,.08);
            border-color: var(--zen-orange);
            box-shadow: 0 0 0 3px rgba(255,86,48,.15);
            color: white;
            outline: none;
        }

        .form-control::placeholder { color: rgba(255,255,255,.25); }

        .btn-login {
            width: 100%;
            background: var(--zen-orange);
            color: white;
            border: none;
            border-radius: 50px;
            padding: 13px;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: opacity .2s, transform .1s;
            margin-top: .5rem;
        }

        .btn-login:hover  { opacity: .9; }
        .btn-login:active { transform: scale(.98); }

        .alert-error {
            background: rgba(220,53,69,.15);
            border: 1px solid rgba(220,53,69,.3);
            border-radius: 10px;
            color: #ff8080;
            padding: 12px 16px;
            font-size: .875rem;
            margin-bottom: 1.2rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .login-footer {
            text-align: center;
            margin-top: 1.8rem;
            color: rgba(255,255,255,.2);
            font-size: .75rem;
        }

        .back-link {
            display: block;
            text-align: center;
            margin-top: 1.2rem;
            color: rgba(255,255,255,.35);
            font-size: .82rem;
            text-decoration: none;
            transition: color .2s;
        }

        .back-link:hover { color: var(--zen-orange); }
    </style>
</head>
<body>

    <div class="login-card">

        <div class="login-logo">
            <span>ZenCAR</span>
            <small>Administration</small>
        </div>

        <p class="login-title">Connexion</p>

        {% if error %}
        <div class="alert-error">
            <i class="bi bi-exclamation-circle-fill"></i>
            Email ou mot de passe incorrect.
        </div>
        {% endif %}

        <form method="post" action="{{ path('app_login') }}">

            <div class="input-wrap">
                <label class="form-label" for="email">Adresse email</label>
                <i class="bi bi-envelope-fill"></i>
                <input type="email"
                       id="email"
                       name="_username"
                       class="form-control"
                       value="{{ last_username }}"
                       placeholder="admin@zencar.fr"
                       autocomplete="email"
                       required
                       autofocus>
            </div>

            <div class="input-wrap">
                <label class="form-label" for="password">Mot de passe</label>
                <i class="bi bi-lock-fill"></i>
                <input type="password"
                       id="password"
                       name="_password"
                       class="form-control"
                       placeholder="••••••••"
                       autocomplete="current-password"
                       required>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button class="btn-login" type="submit">
                <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter
            </button>

        </form>

        <a href="{{ path('app_home') }}" class="back-link">
            <i class="bi bi-arrow-left me-1"></i>Retour au site
        </a>

        <div class="login-footer">© {{ "now"|date("Y") }} ZenCAR — Accès réservé</div>

    </div>

</body>
</html>
