{% if forfaits is defined and forfaits|length > 0 %}
<section class="zen-section" style="background:#0d1117;">
    <div class="container">
        <h2 class="text-center text-white mb-1 h4">Forfaits VTC</h2>
        <p class="text-center mb-5" style="color:#aaa;font-size:.9rem;">
            Prix fixe affiché avant confirmation — Tarif VTC uniquement
        </p>
        <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-lg-3 justify-content-center">
            {% for forfait in forfaits %}
            <div class="col">
                <div class="zen-card h-100 text-center" style="border:1px solid rgba(255,86,48,.2);">
                    {% if forfait.icone %}
                    <div class="zen-card-icon"><i class="{{ forfait.icone }}"></i></div>
                    {% endif %}
                    <div class="mb-2" style="color:#aaa;font-size:.85rem;">
                        {{ forfait.depart }} → {{ forfait.arrivee }}
                    </div>
                    <div class="fw-bold text-white" style="font-size:2rem;">
                        {{ forfait.prix }} €
                    </div>
                    <div class="mt-3">
                        {% if forfait.distance is not null %}
                        <button type="button" class="btn-zen btn-zen-pill qb-open-modal"
                                style="font-size:.85rem;padding:8px 20px;"
                                data-bs-toggle="modal"
                                data-bs-target="#quickBookModal"
                                data-forfait-id="{{ forfait.id }}"
                                data-forfait-label="{{ forfait.depart }} → {{ forfait.arrivee }}"
                                data-forfait-prix="{{ forfait.prix }}">
                            <i class="bi bi-lightning-fill"></i> Réserver maintenant
                        </button>
                        {% else %}
                        <a href="tel:+33674039694" class="btn-zen btn-zen-pill"
                           style="font-size:.85rem;padding:8px 20px;">
                            <i class="bi bi-telephone-fill"></i> Réserver ce forfait
                        </a>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
        <p class="text-center mt-4" style="color:#666;font-size:.8rem;">
            * Tarifs VTC. Le taxi est facturé au compteur selon les tarifs officiels de la Ville de Marseille.
        </p>
    </div>
</section>

{# Modal réservation rapide — affiché uniquement si au moins un forfait a une distance #}
{% set has_quick_book = false %}
{% for f in forfaits %}{% if f.distance is not null %}{% set has_quick_book = true %}{% endif %}{% endfor %}

{% if has_quick_book %}
<div class="modal fade" id="quickBookModal" tabindex="-1" aria-labelledby="quickBookModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background:#1a2030;border:1px solid rgba(255,86,48,.3);border-radius:16px;">
            <div class="modal-header" style="border-color:rgba(255,86,48,.15);">
                <div>
                    <h5 class="modal-title text-white mb-0" id="quickBookModalLabel">
                        <i class="bi bi-lightning-fill me-2" style="color:#ff5630;"></i>Réservation rapide
                    </h5>
                    <small id="qbLabel" style="color:#aaa;"></small>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="d-flex justify-content-between align-items-center mb-4 p-3"
                     style="background:rgba(255,86,48,.08);border-radius:10px;border:1px solid rgba(255,86,48,.15);">
                    <span style="color:#ccc;font-size:.9rem;" id="qbLabelFull"></span>
                    <span class="fw-bold" style="color:#ff5630;font-size:1.4rem;" id="qbPrix"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label" style="color:rgba(255,255,255,.7);font-size:.85rem;">Prénom *</label>
                    <input type="text" id="qbPrenom" class="form-control" placeholder="Prénom du client"
                           style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:10px;color:white;">
                </div>
                <div class="mb-3">
                    <label class="form-label" style="color:rgba(255,255,255,.7);font-size:.85rem;">Téléphone *</label>
                    <input type="tel" id="qbTelephone" class="form-control" placeholder="06 XX XX XX XX"
                           inputmode="tel" pattern="[0-9+\s().-]*"
                           style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:10px;color:white;">
                </div>
                <div class="mb-2">
                    <label class="form-label" style="color:rgba(255,255,255,.7);font-size:.85rem;">Règlement</label>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-outline-info flex-fill qb-mode active" data-mode="carte_bancaire" style="border-radius:10px;">
                            <i class="bi bi-credit-card me-1"></i>Carte
                        </button>
                        <button type="button" class="btn btn-outline-success flex-fill qb-mode" data-mode="especes" style="border-radius:10px;">
                            <i class="bi bi-cash me-1"></i>Espèces
                        </button>
                    </div>
                </div>
                <p id="qbError" class="text-danger mt-2 mb-0 d-none" style="font-size:.85rem;"></p>
            </div>
            <div class="modal-footer" style="border-color:rgba(255,86,48,.15);">
                <button type="button" id="qbSubmitBtn" class="btn w-100 fw-bold py-3"
                        style="background:#ff5630;color:#fff;border-radius:50px;border:none;">
                    <i class="bi bi-check-lg me-2"></i>Confirmer la réservation
                </button>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    let qbForfaitId = null;
    let qbMode = 'carte_bancaire';

    document.querySelectorAll('.qb-open-modal').forEach(btn => {
        btn.addEventListener('click', () => {
            qbForfaitId = btn.dataset.forfaitId;
            document.getElementById('qbLabel').textContent = btn.dataset.forfaitLabel;
            document.getElementById('qbLabelFull').textContent = btn.dataset.forfaitLabel;
            document.getElementById('qbPrix').textContent = btn.dataset.forfaitPrix + ' €';
            document.getElementById('qbPrenom').value = '';
            document.getElementById('qbTelephone').value = '';
            document.getElementById('qbError').classList.add('d-none');
            const sb = document.getElementById('qbSubmitBtn');
            sb.disabled = false;
            sb.innerHTML = '<i class="bi bi-check-lg me-2"></i>Confirmer la réservation';
            qbMode = 'carte_bancaire';
            document.querySelectorAll('.qb-mode').forEach(b => b.classList.toggle('active', b.dataset.mode === 'carte_bancaire'));
        });
    });

    document.querySelectorAll('.qb-mode').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.qb-mode').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            qbMode = btn.dataset.mode;
        });
    });

    document.getElementById('qbSubmitBtn').addEventListener('click', async () => {
        const prenom    = document.getElementById('qbPrenom').value.trim();
        const telephone = document.getElementById('qbTelephone').value.trim();
        const errEl     = document.getElementById('qbError');

        if (!prenom || !telephone) {
            errEl.textContent = 'Prénom et téléphone sont obligatoires.';
            errEl.classList.remove('d-none');
            return;
        }

        const sb = document.getElementById('qbSubmitBtn');
        sb.disabled = true;
        sb.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>En cours…';

        try {
            const resp = await fetch('/reservation/quick-book', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ forfaitId: qbForfaitId, prenom, telephone, modeReglement: qbMode }),
            });
            const data = await resp.json();
            if (resp.ok && data.redirect) {
                window.location.href = data.redirect;
            } else {
                errEl.textContent = data.error || 'Erreur lors de la réservation.';
                errEl.classList.remove('d-none');
                sb.disabled = false;
                sb.innerHTML = '<i class="bi bi-check-lg me-2"></i>Confirmer la réservation';
            }
        } catch {
            errEl.textContent = 'Erreur réseau. Veuillez réessayer.';
            errEl.classList.remove('d-none');
            sb.disabled = false;
            sb.innerHTML = '<i class="bi bi-check-lg me-2"></i>Confirmer la réservation';
        }
    });
})();
</script>
{% endif %}
{% endif %}
